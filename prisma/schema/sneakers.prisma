model SneakerModel {
  id        String    @id @default(cuid())
  name      String
  brand     String
  colorway  String?   @default("")
  releaseAt String?   @default("") @map("release_at")
  imageUrl  String?   @default("") @map("image_url")
  price     Decimal
  slug      String    @unique
  items     Sneaker[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sneaker_model")
}

model Sneaker {
  id             String       @id @default(cuid()) @map("id")
  sneakerModelId String       @map("sneaker_model_id")
  sneakerModel   SneakerModel @relation(fields: [sneakerModelId], references: [id])
  size           Float
  quantity       Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([sneakerModelId, size])
  @@map("sneaker")
}

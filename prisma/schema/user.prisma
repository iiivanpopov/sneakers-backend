model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  phone        String   @unique
  hashPassword String   @map("hash_password")
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  token        Token?

  @@map("user")
}

enum Role {
  CUSTOMER
  MANAGER
  ADMIN
}
